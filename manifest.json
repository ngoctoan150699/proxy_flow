{
  "manifest_version": 3,
  "name": "ProxyFlow - Smart Proxy Picker",
  "description": "Chọn nhanh proxy công khai, random theo quốc gia và kiểm tra IP hiện tại qua WhatIsMyIPAddress.",
  "version": "1.1.0",
  "author": "ProxyFlow Clean-room Extension",
  "permissions": [
    "proxy",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://raw.githubusercontent.com/monosans/proxy-list/*",
    "https://whatismyipaddress.com/*"
  ],
  "action": {
    "default_title": "ProxyFlow",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.svg",
    "32": "icons/icon32.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}
